# りなれす backend 環境変数サンプル（秘匿値は空。実値はコミットしない）
# ローカルは backend/.env に値を入れる（.gitignore 済み）。本番は Azure Container App の env に設定する。

# アプリ独自セッション通行証（HS256 JWT）の署名鍵。
#   生成例: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   未設定時: ローカル(SQLite)のみ dev 専用の弱鍵にフォールバックする。
#             本番(PostgreSQL=非SQLite の DATABASE_URL)では未設定だと発行/検証を拒否する（fail-closed）。
SESSION_SECRET=

# DB 接続文字列（未設定なら backend/data/rinaresu.db の SQLite）
DATABASE_URL=

# Google OAuth クライアントID（非秘匿。未設定なら google_auth.py の既定値）
GOOGLE_CLIENT_ID=

# CORS 許可オリジン（カンマ区切り。未設定なら http://localhost:3000）
CORS_ORIGINS=

# 開発用 /api/dev/* の有効化（"0" で無効。本番は 0）
ENABLE_DEV_API=

# Azure OpenAI（未設定ならモック/テンプレにフォールバック）
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
